{
  "name": "crossloadr",
  "version": "1.0.0",
  "description": "A secure web app store with iOS web clip profiles",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"nodemon src/server.js\" \"cd frontend && npm run dev\"",
