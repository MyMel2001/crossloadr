    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "node-schedule": "^2.1.1",
    "plist": "^3.1.0",
    "quick.db": "^9.1.7",
    "react-router": "^7.17.0",
